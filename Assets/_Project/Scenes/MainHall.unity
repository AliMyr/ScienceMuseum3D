  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=50><b>\u0410\u0442\u0442\u0440\u0430\u043A\u0442\u043E\u0440 \u041B\u043E\u0440\u0435\u043D\u0446\u0430</b></size>\r\n\r\n    
    \u041F\u0440\u043E\u0441\u0442\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0438\u0437 \u0442\u0440\u0451\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0435
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0432 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0435.
    \u041F\u0440\u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0445
    \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u0430\u0445 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0435\u0442\u0441\u044F.\r\n\r\n    
    <size=55><b><color=#FFD966>\u042D\u0444\u0444\u0435\u043A\u0442 \u0431\u0430\u0431\u043E\u0447\u043A\u0438</color></b></size>\r\n\r\n    
    <size=32><i>\u041C\u0430\u043B\u0435\u0439\u0448\u0435\u0435 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u0439
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442 \u043A \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u043D\u043E\u0439 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438.
    \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u041B\u043E\u0440\u0435\u043D\u0446\u0430,
    1963 \u0433\u043E\u0434.</i></size>"

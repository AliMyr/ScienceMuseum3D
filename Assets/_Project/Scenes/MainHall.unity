  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScienceMuseum.Exhibits.PendulumExhibit
  title: "\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0430\u044F\u0442\u043D\u0438\u043A"
  description: "\u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u043E\u0434\u0435\u043B\u044C \u043C\u0430\u044F\u0442\u043D\u0438\u043A\u0430:
    \u0442\u043E\u0447\u0435\u0447\u043D\u0430\u044F \u043C\u0430\u0441\u0441\u0430
    \u043D\u0430 \u043D\u0435\u0432\u0435\u0441\u043E\u043C\u043E\u0439 \u043D\u0438\u0442\u0438.
    \u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u043F\u0435\u0440\u0438\u043E\u0434\u0430
    \u043C\u0430\u043B\u044B\u0445 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439:
    T = 2\u03C0\u221A(L/g). \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u043C\u0435\u043D\u044F\u0442\u044C
    \u0434\u043B\u0438\u043D\u0443 \u043D\u0438\u0442\u0438 \u2014 \u043A\u0430\u043A
    \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u0441\u044F \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u043A\u0430\u0447\u0430\u043D\u0438\u044F?"

  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScienceMuseum.Exhibits.LorenzExhibit
  exhibitId: lorenz
  title: "\u0410\u0442\u0442\u0440\u0430\u043A\u0442\u043E\u0440 \u041B\u043E\u0440\u0435\u043D\u0446\u0430"
  description: "\u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \xAB\u0431\u0430\u0431\u043E\u0447\u043A\u0430\xBB
    \u041B\u043E\u0440\u0435\u043D\u0446\u0430 \u2014 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u043F\u043E\u0440\u043E\u0436\u0434\u0430\u044E\u0442
    \u0441\u043B\u043E\u0436\u043D\u043E\u0435 \u0445\u0430\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435. \u041C\u0435\u043D\u044F\u0439
    \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u044B sigma, rho, beta \u0438
    \u0441\u043C\u043E\u0442\u0440\u0438 \u043A\u0430\u043A \u0438\u0437\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F \u0442\u043E\u0447\u043A\u0438."
  highlightRenderer: {fileID: 1792932268}
  highlightColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  highlightIntensity: 2
  sigma: 10
  rho: 28
  beta: 2.6666667
  x0: 1
  y0: 1
  z0: 1

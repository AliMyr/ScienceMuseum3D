  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=50><b>\u041E\u0440\u0431\u0438\u0442\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u044B</b></size>\r\n\r\n\u0413\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u044F
    \u0421\u043E\u043B\u043D\u0446\u0430 \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
    \u043F\u043B\u0430\u043D\u0435\u0442\u0443. \u0412\u0438\u0434 \u043E\u0440\u0431\u0438\u0442\u044B
    \u2014 \u043A\u0440\u0443\u0433, \u044D\u043B\u043B\u0438\u043F\u0441, \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u0430
    \u0438\u043B\u0438 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0430 \u2014
    \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0442 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438.\r\n\r\n<size=55><b><color=#FFD966>v1
    = sqrt(mu/r)</color></b></size>\r\n\r\n<size=32><i>\u041F\u0435\u0440\u0432\u0430\u044F
    \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u0434\u043B\u044F \u043A\u0440\u0443\u0433\u043E\u0432\u043E\u0439 \u043E\u0440\u0431\u0438\u0442\u044B.
    \u0414\u043B\u044F \u043E\u0442\u0440\u044B\u0432\u0430 \u043D\u0443\u0436\u043D\u0430
    v2 = v1 \xB7 sqrt(2).</i></size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}

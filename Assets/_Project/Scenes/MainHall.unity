  m_Script: {fileID: 11500000, guid: 3baebc1a07ca55f4ab0e7f17fbc81a49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScienceMuseum.Exhibits.OrbitExhibit
  exhibitId: orbit
  title: "\u041E\u0440\u0431\u0438\u0442\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u044B"
  description: "\u041F\u043B\u0430\u043D\u0435\u0442\u0430 \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u0432 \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u043C
    \u043F\u043E\u043B\u0435 \u0421\u043E\u043B\u043D\u0446\u0430. \u0412\u0438\u0434
    \u043E\u0440\u0431\u0438\u0442\u044B \u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u043E\u0442 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438.
    \u041F\u0440\u043E\u0432\u0435\u0440\u044C \u043A\u0430\u043A \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F \u2014 \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u043A\u0440\u0443\u0433\u043E\u0432\u043E\u0439, \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043B\u0438 \u043F\u043B\u0430\u043D\u0435\u0442\u0430 \u0443\u043B\u0435\u0442\u0438\u0442
    \u0432 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C."

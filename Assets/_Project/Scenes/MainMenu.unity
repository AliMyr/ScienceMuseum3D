      m_Calls: []
  m_text: "<b>\u0422\u0435\u043C\u0430 \u0434\u0438\u043F\u043B\u043E\u043C\u0430:</b>\r\n\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u043E\u0433\u043E \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u0430
    \u0434\u043B\u044F \u0438\u043D\u0442\u0435\u0440\u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u043C\u043E\u0434\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0432\u0438\u0437\u0443\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432\r\n\r\n<b>\u0410\u0432\u0442\u043E\u0440:</b>
    \u041C\u044B\u0440\u0437\u0430\u043B\u0438\u0435\u0432 \u0410\u043B\u0438\r\n<b>\u0413\u0440\u0443\u043F\u043F\u0430:</b>
    \u0418\u0422\u0420-23-312-11\r\n<b>\u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C:</b>
    \u0410\u0431\u0438\u043B\u044C\u0442\u0430\u0435\u0432 \u0414\u0430\u0441\u0442\u0430\u043D\r\n<b>\u0413\u043E\u0434:</b>
    2026\r\n\r\n<b>\u041E \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438:</b>\r\n3D-\u043C\u0443\u0437\u0435\u0439
    \u0441 \u0438\u043D\u0442\u0435\u0440\u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C\u0438
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u044D\u043A\u0441\u043F\u043E\u043D\u0430\u0442\u0430\u043C\u0438.
    \u0420\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043D\u043E \u043D\u0430
    Unity 6 LTS \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u041E\u0414\u0423 (\u0420\u0443\u043D\u0433\u0435-\u041A\u0443\u0442\u0442\u0430
    4-\u0433\u043E \u043F\u043E\u0440\u044F\u0434\u043A\u0430).\r\n\r\n<b>\u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435:</b>\r\nWASD
    \u2014 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435, \u043C\u044B\u0448\u044C
    \u2014 \u043E\u0431\u0437\u043E\u0440, Shift \u2014 \u0431\u0435\u0433, E \u2014
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C,
    M \u2014 \u043A\u0430\u0440\u0442\u0430 \u043C\u0443\u0437\u0435\u044F, Esc \u2014
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u043F\u0430\u043D\u0435\u043B\u044C"
